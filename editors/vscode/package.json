{
  "name": "spin-lang",
  "displayName": "Spin Language",
  "description": "Language support for .spin files — syntax highlighting, autocomplete, hover, and rename",
  "version": "0.1.0",
  "publisher": "freshtonic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/freshtonic/spin-up"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:spin"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "spin",
        "aliases": [
          "Spin",
          "spin"
        ],
        "extensions": [
          ".spin"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "spin",
        "scopeName": "source.spin",
        "path": "./syntaxes/spin.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Spin Language",
      "properties": {
        "spin.lsp.path": {
          "type": "string",
          "default": "spin-lsp",
          "description": "Path to the spin-lsp binary. Defaults to finding it on PATH."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
