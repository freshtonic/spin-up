{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Spin",
  "scopeName": "source.spin",
  "patterns": [
    { "include": "#comments" },
    { "include": "#attributes" },
    { "include": "#regex" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#primitive-types" },
    { "include": "#builtin-values" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#type-names" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.spin",
          "match": "//.*$"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.spin",
          "begin": "#\\[",
          "end": "\\]",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.attribute.begin.spin" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.attribute.end.spin" }
          },
          "patterns": [
            {
              "name": "entity.other.attribute-name.spin",
              "match": "[a-zA-Z_][a-zA-Z0-9_-]*"
            },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.spin",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.spin",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.spin",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.spin" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.spin" }
              },
              "patterns": [
                {
                  "name": "variable.other.spin",
                  "match": "[a-zA-Z_][a-zA-Z0-9_.]*"
                }
              ]
            }
          ]
        }
      ]
    },
    "regex": {
      "patterns": [
        {
          "name": "string.regexp.spin",
          "begin": "r\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.spin" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.spin" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.spin",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.spin",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.octal.spin",
          "match": "\\b0o[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.float.spin",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.spin",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.spin",
          "match": "\\b(if|then|else)\\b"
        },
        {
          "name": "keyword.other.spin",
          "match": "\\b(import|type|interface|impl|for|let|fn|map|keep|drop|count|sum|mean|median|min|max)\\b"
        },
        {
          "name": "variable.language.spin",
          "match": "\\b(self|Self|it)\\b"
        }
      ]
    },
    "primitive-types": {
      "patterns": [
        {
          "name": "storage.type.primitive.spin",
          "match": "\\b(bool|number|string|Set)\\b"
        }
      ]
    },
    "builtin-values": {
      "patterns": [
        {
          "name": "constant.language.spin",
          "match": "\\b(true|false|None)\\b"
        },
        {
          "name": "entity.name.tag.spin",
          "match": "\\b(Some|Ok|Err)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.spin",
          "match": "=~|==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.logical.spin",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.spin",
          "match": "[+\\-*/]"
        },
        {
          "name": "keyword.operator.assignment.spin",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.spin",
          "match": "->"
        },
        {
          "name": "keyword.operator.path.spin",
          "match": "::"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.spin",
          "match": "[,;:|.]"
        }
      ]
    },
    "type-names": {
      "patterns": [
        {
          "name": "entity.name.type.spin",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.spin",
          "match": "\\b[a-z_][a-zA-Z0-9_-]*\\b"
        }
      ]
    }
  }
}
